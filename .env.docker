# AgentHive Cloud - Docker 镜像版本统一配置
# 此文件由构建脚本自动生成/读取，请勿手动修改 tag

# 基础版本号（语义化版本）
VERSION=1.0.0

# Git 提交短哈希（自动注入，用于问题追溯）
GIT_COMMIT=cffadb8

# 构建时间 ISO 8601（自动注入）
BUILD_TIME=2026-04-22T12:59:35Z

# 最终镜像标签 = VERSION-GIT_COMMIT
IMAGE_TAG=1.0.0-cffadb8

# 镜像仓库前缀
REGISTRY_PREFIX=agenthive

# 各服务镜像名（仅名称部分，不含 tag）
IMAGE_API=api
IMAGE_LANDING=landing
IMAGE_AGENT_RUNTIME=agent-runtime
IMAGE_AUTH_SERVICE=auth-service
IMAGE_USER_SERVICE=user-service
IMAGE_GATEWAY_SERVICE=gateway-service
IMAGE_PAYMENT_SERVICE=payment-service
IMAGE_ORDER_SERVICE=order-service
IMAGE_CART_SERVICE=cart-service
IMAGE_LOGISTICS_SERVICE=logistics-service

# 构建上下文路径（相对项目根目录）
CONTEXT_API=.
CONTEXT_LANDING=.
CONTEXT_AGENT_RUNTIME=./apps/agent-runtime
CONTEXT_JAVA=./apps/java
