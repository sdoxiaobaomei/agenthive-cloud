# ==========================================
# AgentHive Cloud - Development Environment
# ==========================================

# ==========================================
# Database
# ==========================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=agenthive
DB_PASSWORD=agenthive_dev
DB_NAME=agenthive_dev

# ==========================================
# Redis
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_dev

# ==========================================
# Server
# ==========================================
SUPERVISOR_PORT=8081
SUPERVISOR_TARGET=development
WEB_PORT=5173
WEB_TARGET=development

# ==========================================
# Frontend
# ==========================================
NODE_ENV=development
VITE_API_BASE_URL=http://localhost:8081/api
VITE_WS_URL=ws://localhost:8081/ws

# ==========================================
# Logging
# ==========================================
LOG_LEVEL=debug
LOG_FORMAT=text

# ==========================================
# Security (relaxed for development)
# ==========================================
JWT_SECRET=dev_jwt_secret_not_for_production
CORS_ALLOWED_ORIGINS=*
