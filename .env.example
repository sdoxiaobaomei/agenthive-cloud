# ==========================================
# AgentHive Cloud - Environment Configuration
# ==========================================

# ==========================================
# Database Configuration
# ==========================================
# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=agenthive
DB_PASSWORD=agenthive_secret
DB_NAME=agenthive
DB_SSL_MODE=disable

# Connection Pool
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# ==========================================
# Redis Configuration
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
REDIS_DB=0
REDIS_POOL_SIZE=10

# ==========================================
# JWT Configuration
# ==========================================
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=168h

# ==========================================
# Server Configuration
# ==========================================
# Supervisor API
SUPERVISOR_PORT=8080
SUPERVISOR_HOST=0.0.0.0
SUPERVISOR_TARGET=production

# Web Frontend
WEB_PORT=80
WEB_TARGET=production

# Landing Page (Marketing)
LANDING_PORT=3000

# Nginx
NGINX_HTTP_PORT=8080
NGINX_HTTPS_PORT=8443

# ==========================================
# Frontend Configuration
# ==========================================
NODE_ENV=production

# API URLs (used by frontend)
VITE_API_BASE_URL=http://localhost:8080/api
VITE_WS_URL=ws://localhost:8080/ws
VITE_APP_TITLE=AgentHive Cloud
VITE_APP_VERSION=0.1.0

# ==========================================
# Logging Configuration
# ==========================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT=stdout

# ==========================================
# Object Storage (MinIO)
# ==========================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET_NAME=agenthive
MINIO_ENDPOINT=localhost:9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ==========================================
# Monitoring Configuration
# ==========================================
# Prometheus
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ==========================================
# Email Configuration (Optional)
# ==========================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=AgentHive <noreply@example.com>

# ==========================================
# Feature Flags
# ==========================================
ENABLE_REGISTRATION=true
ENABLE_GUEST_ACCESS=false
ENABLE_ANONYMOUS_ANALYTICS=false

# ==========================================
# Security Settings
# ==========================================
# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:80,http://localhost:8080
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_DURATION=1m

# ==========================================
# Docker Compose Specific
# ==========================================
COMPOSE_PROJECT_NAME=agenthive-cloud

# ==========================================
# Development Only
# ==========================================
# Hot reload for development
AIR_CONFIG=.air.toml

# Debug mode (never enable in production)
DEBUG=false
