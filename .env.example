# AgentHive K3s Secret Template
# =============================
# Copy this file to .env and fill in real values.
# NEVER commit .env to Git!
# Run: bash scripts/setup-secrets.sh

# Database
DB_USER=agenthive
DB_PASSWORD=change-me-strong-password

# Redis (required by PLATFORM-024/025)
REDIS_PASSWORD=agenthive

# RabbitMQ (required by PLATFORM-028/029)
RABBITMQ_PASSWORD=agenthive-secret

# Payment service (required by PLATFORM-029)
INTERNAL_API_TOKEN=change-me-internal-api-token-min-32-chars

# Java User Service (required by NODE-006)
# 如果通过 Gateway 路由，可设为 http://java-gateway:8080
JAVA_USER_SERVICE_URL=http://user-service:8082
WITHDRAWAL_ENCRYPT_KEY=12345678901234567890123456789012

# Java Auth Service (required by NODE-008)
JAVA_AUTH_SERVICE_URL=http://auth-service:8081

# JWT & Auth
JWT_SECRET=change-me-jwt-secret-min-32-chars

# LLM API (e.g. Kimi/OpenAI)
LLM_API_KEY=sk-your-llm-api-key

# Backup Encryption
BACKUP_ENCRYPTION_KEY=change-me-backup-encryption-key

# MinIO (optional, for automated backups)
MINIO_ACCESS_KEY=minio-admin
MINIO_SECRET_KEY=minio-password

# Nacos (Java microservices)
NACOS_AUTH_TOKEN=nacos-auth-token
NACOS_PASSWORD=nacos-password

# Grafana (optional)
GRAFANA_ADMIN_PASSWORD=admin
