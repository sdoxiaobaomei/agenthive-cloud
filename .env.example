# AgentHive Cloud — Environment Variables Template
# =============================================================================
# Copy this file to .env, .env.dev, or .env.prod and fill in the values.
# NEVER commit real .env files to Git (see .gitignore).
#
# K8s-specific notes:
#   - DB_HOST/REDIS_HOST: use K8s service DNS (e.g. postgres.agenthive.svc.cluster.local)
#   - NACOS_SERVER: use K8s service DNS (e.g. nacos.agenthive.svc.cluster.local:8848)
#   - OTEL_EXPORTER_OTLP_ENDPOINT: use monitoring namespace service
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001
APP_NAME=AgentHive Cloud
LOG_LEVEL=info
API_VERSION=v1

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agenthive
DB_USER=agenthive
DB_PASSWORD=                         # REQUIRED — minimum 16 characters
DB_SSL_MODE=disable
MAX_CONNECTIONS=100

# -----------------------------------------------------------------------------
# Cache (Redis)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                      # REQUIRED
REDIS_DB=0
CACHE_TTL=3600

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
JWT_SECRET=                          # REQUIRED — minimum 32 characters, use: openssl rand -hex 32
JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# LLM / AI Integration
# -----------------------------------------------------------------------------
LLM_API_KEY=                         # Your Kimi/OpenAI API key (DO NOT use sk-kimi-... in committed files)
LLM_MODEL=kimi-latest
LLM_BASE_URL=https://api.moonshot.cn/v1

# -----------------------------------------------------------------------------
# Service Discovery (Nacos) — Optional for K8s Phase 1
# -----------------------------------------------------------------------------
NACOS_SERVER=nacos:8848
NACOS_NAMESPACE=public
NACOS_AUTH_ENABLE=true
NACOS_AUTH_TOKEN=                    # REQUIRED if NACOS_AUTH_ENABLE=true
NACOS_AUTH_IDENTITY_KEY=serverIdentity
NACOS_AUTH_IDENTITY_VALUE=           # REQUIRED if NACOS_AUTH_ENABLE=true

# -----------------------------------------------------------------------------
# Message Queue (RabbitMQ) — Optional for K8s Phase 1
# -----------------------------------------------------------------------------
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=agenthive
RABBITMQ_PASSWORD=                   # REQUIRED
RABBITMQ_VHOST=/

# -----------------------------------------------------------------------------
# Observability (OpenTelemetry)
# -----------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector-gateway.monitoring:4317
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_SERVICE_NAME=agenthive
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=0.1
OTEL_LOG_LEVEL=warn
OTEL_SDK_DISABLED=false
STRUCTURED_LOGGING=true

# -----------------------------------------------------------------------------
# CORS / Security
# -----------------------------------------------------------------------------
CORS_ORIGIN=http://localhost:3000    # Production: https://agenthive.cloud,https://www.agenthive.cloud
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# -----------------------------------------------------------------------------
# Monitoring (Grafana)
# -----------------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=              # REQUIRED for production

# -----------------------------------------------------------------------------
# Storage / File Upload
# -----------------------------------------------------------------------------
UPLOAD_MAX_SIZE=10485760
UPLOAD_DIR=/app/uploads
