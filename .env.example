# AgentHive Cloud - Environment Variables
# Copy to .env and customize

# ============================================
# Database (Node.js API)
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=agenthive
DB_PASSWORD=your-secure-password-here
DB_NAME=agenthive

# ============================================
# Redis
# ============================================
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# Node.js API
# ============================================
API_PORT=3001
JWT_SECRET=your-jwt-secret-here-min-32-characters-long
NODE_ENV=development

# ============================================
# Landing (Nuxt)
# ============================================
LANDING_PORT=80
NUXT_PUBLIC_API_BASE_URL=http://localhost:3001

# ============================================
# Agent Runtime
# ============================================
AGENT_RUNTIME_PORT=3002
WORKSPACE_BASE=/data/workspaces

# ============================================
# LLM Configuration
# ============================================
# 支持三种方案，按需选择一种即可：
#
# 【方案 A】Moonshot 普通 API（推荐，无客户端限制，按量付费）
# 从 https://platform.moonshot.cn/ 获取 API Key
# LLM_API_KEY=sk-your-moonshot-api-key
# LLM_BASE_URL=https://api.moonshot.cn/v1
# LLM_MODEL=kimi-latest
# LLM_USER_AGENT=AgentHive/1.0
#
# 【方案 B】Kimi Code API（$20/月 Coding Plan，需伪装 User-Agent）
# 从 https://www.kimi.com/code 获取 API Key
# LLM_API_KEY=sk-kimi-your-code-api-key
# LLM_BASE_URL=https://api.kimi.com/coding/v1
# LLM_MODEL=kimi-for-coding
# LLM_USER_AGENT=claude-code/0.1.0
#
# 【方案 C】Ollama 本地模型（无需联网，需本地运行 Ollama）
OLLAMA_BASE_URL=http://host.docker.internal:11434
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=http://host.docker.internal:11434
LLM_MODEL=qwen3:14b
LLM_USER_AGENT=AgentHive/1.0

# ============================================
# Java Microservices
# ============================================
NACOS_SERVER=localhost:8848
JAVA_GATEWAY_URL=http://localhost:8080
MOCK_JAVA_API=false
HOSTING_DOMAIN=agenthive.io

# Gateway
GATEWAY_PORT=8080

# Auth Service
AUTH_DB_HOST=localhost
AUTH_DB_PORT=5432
AUTH_DB_NAME=auth_db
AUTH_DB_USER=agenthive
AUTH_DB_PASSWORD=your-secure-password-here

# User Service
USER_DB_HOST=localhost
USER_DB_PORT=5433
USER_DB_NAME=user_db
USER_DB_USER=agenthive
USER_DB_PASSWORD=your-secure-password-here

# Payment Service
PAYMENT_DB_HOST=localhost
PAYMENT_DB_PORT=5434
PAYMENT_DB_NAME=payment_db
PAYMENT_DB_USER=agenthive
PAYMENT_DB_PASSWORD=your-secure-password-here

# Credits / Agent Billing
JAVA_PAYMENT_URL=http://localhost:8080
CREDITS_MOCK_MODE=false
INTERNAL_API_TOKEN=your-internal-api-token

# Order Service
ORDER_DB_HOST=localhost
ORDER_DB_PORT=5434
ORDER_DB_NAME=order_db
ORDER_DB_USER=agenthive
ORDER_DB_PASSWORD=your-secure-password-here

# Cart Service
CART_DB_HOST=localhost
CART_DB_PORT=5434
CART_DB_NAME=cart_db
CART_DB_USER=agenthive
CART_DB_PASSWORD=your-secure-password-here

# Logistics Service
LOGISTICS_DB_HOST=localhost
LOGISTICS_DB_PORT=5434
LOGISTICS_DB_NAME=logistics_db
LOGISTICS_DB_USER=agenthive
LOGISTICS_DB_PASSWORD=your-secure-password-here

# ============================================
# RabbitMQ
# ============================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ============================================
# OpenTelemetry / Observability
# ============================================
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_SERVICE_NAME=agenthive-local
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=local,host.name=localhost
OTEL_LOG_LEVEL=info
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0
OTEL_SDK_DISABLED=false

# ============================================
# Monitoring
# ============================================
GRAFANA_PASSWORD=admin123
GRAFANA_PORT=3002
PROMETHEUS_PORT=9090
TEMPO_PORT=3200
LOKI_PORT=3100

# Beyla (eBPF)
BEYLA_OTEL_ENDPOINT=http://localhost:4317
