# ============================================
# AgentHive Auth Service - Docker 环境变量模板
# ============================================
# 复制本文件为 .env 并填入实际值：
#   cp .env.example .env

# --------------------------------------------
# Database（宿主机容器，端口 5433）
# --------------------------------------------
DB_NAME=auth_db
DB_USER=agenthive
DB_PASSWORD=secret

# --------------------------------------------
# Redis（宿主机容器）
# --------------------------------------------
REDIS_PASSWORD=

# --------------------------------------------
# JWT（生产环境必须替换为强随机字符串）
# --------------------------------------------
JWT_SECRET=change-me-in-production-docker-secret-key-2024

# --------------------------------------------
# 阿里云 SMS 凭证（Docker 环境）
#
# 由于 Docker 环境不支持 K8s OIDC，请通过以下方式之一提供凭证：
#
# 方式 A：STS 临时凭证（推荐，相对安全）
#   通过阿里云 CLI 或其他工具获取临时 Token，定期刷新
#   ALIBABA_CLOUD_ACCESS_KEY_ID=STS.xxx
#   ALIBABA_CLOUD_ACCESS_KEY_SECRET=xxx
#   ALIBABA_CLOUD_SECURITY_TOKEN=xxx
#
# 方式 B：长期 AccessKey（仅本地开发）
#   风险提示：长期 AccessKey 泄露后难以撤销，切勿提交到 Git
#   ALIBABA_CLOUD_ACCESS_KEY_ID=LTAIxxx
#   ALIBABA_CLOUD_ACCESS_KEY_SECRET=xxx
# --------------------------------------------
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
ALIBABA_CLOUD_SECURITY_TOKEN=

# --------------------------------------------
# SMS 其他配置
# --------------------------------------------
ALIYUN_SMS_ENABLED=true
ALIYUN_SMS_DEFAULT_SIGN_NAME=云渚科技验证平台
