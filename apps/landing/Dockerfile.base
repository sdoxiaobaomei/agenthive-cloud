# Landing Base Image - Pre-installed server dependencies
# Build once and cache: docker build -f apps/landing/Dockerfile.base -t agenthive/landing-base:latest .
FROM node:20-alpine
WORKDIR /app
# Use Taobao npm registry for faster installs in China
RUN npm config set registry https://registry.npm.taobao.org
COPY apps/landing/.output-new/server/package.json ./
RUN npm install --omit=dev --no-audit --no-fund --progress=false --prefer-offline
