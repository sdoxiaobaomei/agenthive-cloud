# syntax=docker/dockerfile:1
# Landing Base Image - Pre-installed server dependencies (for SSR caching)
# Build: docker build -f apps/landing/Dockerfile.base -t agenthive/landing-base:latest .

FROM node:20-alpine

WORKDIR /app

# Use Taobao npm registry for faster installs in China (optional)
RUN npm config set registry https://registry.npmmirror.com

# Copy the server-side package.json generated by Nuxt build
COPY apps/landing/.output/server/package.json ./

# Install only production server dependencies
RUN npm install --omit=dev --no-audit --no-fund --progress=false --prefer-offline
