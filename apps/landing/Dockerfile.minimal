# syntax=docker/dockerfile:1
# Landing 最小化构建 Dockerfile - 静态生成 (nginx)
# Build: docker build -f apps/landing/Dockerfile.minimal -t agenthive/landing:<tag> .

# ============ 依赖安装阶段 ============
FROM node:20-alpine AS deps

WORKDIR /app

RUN npm install -g pnpm@9

COPY pnpm-workspace.yaml package.json ./
COPY pnpm-lock.yaml ./
COPY packages/types/package.json ./packages/types/
COPY apps/landing/package.json ./apps/landing/

RUN pnpm install --frozen-lockfile

# ============ 构建阶段 ============
FROM node:20-alpine AS builder

WORKDIR /app

RUN npm install -g pnpm@9

COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/pnpm-workspace.yaml ./pnpm-workspace.yaml
COPY --from=deps /app/package.json ./package.json

COPY packages/types ./packages/types
COPY apps/landing ./apps/landing

RUN pnpm --filter=@agenthive/types build
RUN pnpm --filter=agenthive-landing build

# ============ 生产阶段 ============
FROM nginx:alpine

COPY --from=builder /app/apps/landing/.output/public /usr/share/nginx/html

RUN echo 'server { listen 80; location / { root /usr/share/nginx/html; index index.html; try_files $uri $uri/ /index.html; } }' > /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
