{
    "name": "agenthive-landing",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "nuxt dev",
        "build": "nuxt build",
        "generate": "nuxt generate",
        "preview": "nuxt preview",
        "typecheck": "nuxt typecheck",
        "postinstall": "nuxt prepare",
        "clean": "node -e \"require('fs').rmSync('.nuxt-build/dist',{recursive:true,force:true}); require('fs').rmSync('.nuxt-build/dev',{recursive:true,force:true}); require('fs').rmSync('.output',{recursive:true,force:true}); require('fs').rmSync('.vite-cache',{recursive:true,force:true}); console.log('Cleaned build artifacts')\"",
        "test": "vitest run --passWithNoTests",
        "test:e2e": "playwright test",
        "lint": "echo 'No linter configured for Landing yet'"
    },
    "dependencies": {
        "@agenthive/observability": "workspace:*",
        "@agenthive/types": "workspace:*",
        "@element-plus/icons-vue": "^2.3.2",
        "@nuxtjs/tailwindcss": "^6.12.0",
        "@opentelemetry/api": "^1.8.0",
        "@opentelemetry/auto-instrumentations-node": "^0.47.0",
        "@opentelemetry/exporter-metrics-otlp-grpc": "^0.51.0",
        "@opentelemetry/exporter-trace-otlp-grpc": "^0.51.0",
        "@opentelemetry/resources": "^1.24.0",
        "@opentelemetry/sdk-metrics": "^1.24.0",
        "@opentelemetry/sdk-node": "^0.51.0",
        "@opentelemetry/semantic-conventions": "^1.24.0",
        "@pinia/nuxt": "^0.11.3",
        "@vueuse/nuxt": "^10.9.0",
        "axios": "^1.14.0",
        "element-plus": "^2.13.6",
        "gsap": "^3.14.2",
        "naive-ui": "^2.44.1",
        "nuxt": "^3.11.2",
        "pinia": "^3.0.4",
        "pinia-plugin-persistedstate": "^4.7.1",
        "socket.io-client": "^4.8.3",
        "vue": "^3.4.21",
        "vue-router": "^4.3.0"
    },
    "devDependencies": {
        "@nuxt/devtools": "latest",
        "@playwright/test": "^1.59.1",
        "@vitejs/plugin-vue": "^5.0.0",
        "jsdom": "^24.0.0",
        "typescript": "^5.4.5",
        "vitest": "^1.6.0",
        "vue-tsc": "^2.2.0"
    }
