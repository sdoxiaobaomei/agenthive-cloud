# syntax=docker/dockerfile:1
# API 生产构建 Dockerfile - 本地预构建版本
# 假设你已经在本地运行过 npm run build（从 monorepo 根目录构建）
# Build: docker build -f apps/api/deploy/Dockerfile.prod -t agenthive/api:<tag> .

FROM node:20-alpine AS production

RUN apk add --no-cache dumb-init

WORKDIR /app

# Copy only production artifacts
COPY apps/api/dist ./dist
COPY apps/api/package.json ./

# Install pnpm to resolve workspace deps locally
RUN npm install -g pnpm@9

# Copy workspace packages (built dist only) that API depends on
COPY packages/observability/package.json ./packages/observability/
COPY packages/observability/dist ./packages/observability/dist
COPY apps/agent-runtime/package.json ./apps/agent-runtime/
COPY apps/agent-runtime/dist ./apps/agent-runtime/dist
COPY pnpm-workspace.yaml ./
COPY package.json ./

# Install only production dependencies (workspace links resolved by pnpm)
RUN pnpm install --prod --frozen-lockfile

# Create non-root user
RUN addgroup -g 1001 -S nodejs && \
    adduser -S nodejs -u 1001 && \
    chown -R nodejs:nodejs /app

USER nodejs

EXPOSE 3001

HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD node -e "require('http').get('http://localhost:3001/api/health', (r) => r.statusCode === 200 ? process.exit(0) : process.exit(1))"

ENTRYPOINT ["dumb-init", "--"]
CMD ["node", "dist/index.js"]
