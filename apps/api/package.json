{
    "name": "@agenthive/api",
    "version": "1.0.0",
    "description": "AgentHive Cloud API Server",
    "type": "module",
    "scripts": {
        "dev": "npm run migrate:up && tsx watch src/index.ts",
        "build": "tsc",
        "start": "npm run migrate:up && node --require dotenv/config dist/index.js",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:ui": "vitest --ui",
        "typecheck": "tsc --noEmit",
        "lint": "echo 'No linter configured for API yet'",
        "db:init": "tsx scripts/init-db.ts",
        "db:migrate": "node-pg-migrate",
        "migrate:up": "node-pg-migrate up",
        "migrate:down": "node-pg-migrate down",
        "migrate:status": "node-pg-migrate up --dry-run",
        "migrate:create": "node-pg-migrate create",
        "migrate:repair": "node-pg-migrate repair",
        "consumer": "tsx src/bin/task-consumer.ts",
        "consumer:watch": "tsx watch src/bin/task-consumer.ts"
    },
    "dependencies": {
        "@agenthive/agent-runtime": "workspace:*",
        "@agenthive/observability": "workspace:*",
        "@opentelemetry/api": "^1.8.0",
        "@opentelemetry/auto-instrumentations-node": "^0.47.0",
        "@opentelemetry/exporter-metrics-otlp-grpc": "^0.51.0",
        "@opentelemetry/exporter-trace-otlp-grpc": "^0.51.0",
        "@opentelemetry/resources": "^1.24.0",
        "@opentelemetry/sdk-metrics": "^1.24.0",
        "@opentelemetry/sdk-node": "^0.51.0",
        "@opentelemetry/semantic-conventions": "^1.24.0",
        "@socket.io/redis-adapter": "^8.3.0",
        "cookie-parser": "^1.4.6",
        "cors": "^2.8.5",
        "dotenv": "^16.4.0",
        "express": "^4.18.2",
        "express-rate-limit": "^8.4.1",
        "ioredis": "^5.10.1",
        "multer": "^2.1.1",
        "node-pg-migrate": "^8.0.4",
        "pg": "^8.11.3",
        "socket.io": "^4.8.3",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1",
        "ws": "^8.16.0",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/cookie-parser": "^1.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/multer": "^2.1.0",
        "@types/node": "^20.10.0",
        "@types/pg": "^8.11.0",
        "@types/supertest": "^6.0.2",
        "@types/swagger-jsdoc": "^6.0.4",
        "@types/swagger-ui-express": "^4.1.7",
        "@vitest/coverage-v8": "^1.3.0",
        "@vitest/ui": "^1.3.0",
        "supertest": "^6.3.4",
        "tsx": "^4.7.0",
        "typescript": "^5.3.0",
        "vitest": "^1.3.0"
    }
}
