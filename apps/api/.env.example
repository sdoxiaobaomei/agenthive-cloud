# AgentHive API 环境变量配置

# 服务器端口
PORT=3001

# Gateway 信任模式（生产环境必须启用）
# 当请求携带 X-User-Id header 时，API 直接信任 Gateway 的身份透传
# Node API 不再自己做 JWT 验证，统一由 Java Gateway 处理认证
TRUST_GATEWAY=true

# 开发环境模拟用户配置（仅 NODE_ENV=development 生效）
# 用于本地直连调试，不经过 Gateway 时自动注入用户身份
DEV_USER_ID=dev-user-id
DEV_USER_NAME=Developer
DEV_USER_ROLE=admin

# CORS 配置
CORS_ORIGIN=http://localhost:3000

# PostgreSQL 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agenthive
DB_USER=agenthive
DB_PASSWORD=agenthive123

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# LLM 配置（三选一，优先使用 OpenAI 兼容 API）
# 方案 A: Kimi Code API（推荐，无需本地 GPU）
# LLM_BASE_URL=https://api.kimi.com/coding/v1
# LLM_API_KEY=sk-your-kimi-code-api-key
# LLM_MODEL=kimi-code

# 方案 B: 阿里云百炼（OpenAI 兼容 API）
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_API_KEY=sk-your-dashscope-api-key
# LLM_MODEL=qwen-max

# 方案 C: Ollama 本地模型（需本机运行 ollama，内存要求 8G+）
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=qwen3:14b
