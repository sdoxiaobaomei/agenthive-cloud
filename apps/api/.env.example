# AgentHive API 环境变量配置

# 服务器端口
PORT=3001

# JWT 密钥
JWT_SECRET=your-secret-key-change-in-production

# CORS 配置
CORS_ORIGIN=http://localhost:3000

# PostgreSQL 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agenthive
DB_USER=agenthive
DB_PASSWORD=agenthive123

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# LLM 配置（三选一，优先使用 OpenAI 兼容 API）
# 方案 A: Kimi Code API（推荐，无需本地 GPU）
# LLM_BASE_URL=https://api.kimi.com/coding/v1
# LLM_API_KEY=sk-your-kimi-code-api-key
# LLM_MODEL=kimi-code

# 方案 B: 阿里云百炼（OpenAI 兼容 API）
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_API_KEY=sk-your-dashscope-api-key
# LLM_MODEL=qwen-max

# 方案 C: Ollama 本地模型（需本机运行 ollama，内存要求 8G+）
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=qwen3:14b
