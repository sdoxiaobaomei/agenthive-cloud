# AgentHive API 环境变量配置

# 服务器端口
PORT=3001

# JWT 密钥
JWT_SECRET=your-secret-key-change-in-production

# CORS 配置
CORS_ORIGIN=http://localhost:3000

# PostgreSQL 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agenthive
DB_USER=agenthive
DB_PASSWORD=agenthive123

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
