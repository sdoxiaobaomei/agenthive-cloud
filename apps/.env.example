# ============================================
# AgentHive Cloud - 环境变量配置示例
# ============================================
# 复制此文件为 .env 并根据需要修改值
# ============================================

# --------------------------------------------
# Nuxt 应用公开配置 (客户端可用)
# --------------------------------------------

# API Base URL - 开发环境
# 默认走相对路径 /api，由 Nuxt BFF (server/api/) 统一代理到 Gateway (8080)
# 如需直连（如调试跨域），可设为 http://localhost:8080
# NUXT_PUBLIC_API_BASE=http://localhost:3001

# API Base URL - 生产环境（部署时启用）
# NUXT_PUBLIC_API_BASE=https://api.agenthive.cloud

# 应用名称
NUXT_PUBLIC_APP_NAME=AgentHive

# 应用版本
NUXT_PUBLIC_APP_VERSION=1.0.0

# --------------------------------------------
# 服务端私有配置 (服务端可用，客户端不可访问)
# --------------------------------------------

# JWT 密钥（生产环境必须使用强密钥）
# NUXT_API_SECRET=your-secret-key-here

# 数据库连接字符串
# DATABASE_URL=postgresql://user:pass@localhost:5432/agenthive

# Redis 连接字符串
# REDIS_URL=redis://localhost:6379
