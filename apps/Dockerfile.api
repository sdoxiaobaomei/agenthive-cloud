# API 生产构建 Dockerfile - Monorepo 完整构建版本
# 从 agenthive-cloud 根目录构建

# ============ 构建阶段 ============
FROM node:20-alpine AS builder

WORKDIR /app

# 安装 pnpm
RUN npm install -g pnpm

# 先复制 workspace 配置
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml ./
COPY packages/types ./packages/types

# 复制 API 和依赖的 agent-runtime
COPY apps/api ./apps/api
COPY apps/agent-runtime ./apps/agent-runtime

# 安装所有依赖（包括 workspace 依赖）
RUN pnpm install --frozen-lockfile

# 先构建共享包
RUN cd packages/types && pnpm build 2>/dev/null || true
RUN cd apps/agent-runtime && pnpm build 2>/dev/null || true

# 构建 API
RUN cd apps/api && pnpm build

# ============ 生产阶段 ============
FROM node:20-alpine

RUN apk add --no-cache dumb-init

WORKDIR /app

# 从构建阶段复制
COPY --from=builder /app/apps/api/dist ./dist
COPY --from=builder /app/apps/api/package*.json ./
COPY --from=builder /app/node_modules ./node_modules

# 创建非 root 用户
RUN addgroup -g 1001 -S nodejs && \
    adduser -S nodejs -u 1001 && \
    chown -R nodejs:nodejs /app

USER nodejs

EXPOSE 3001

ENTRYPOINT ["dumb-init", "--"]
CMD ["node", "dist/index.js"]
