# ============================================
# AgentHive 演示环境配置
# 8C16G 业务层 + 2C2G 数据层 (172.24.146.165)
# ============================================

# ---- 数据层配置（2C2G ECS 内网地址）----
DB_HOST=172.24.146.165
DB_PORT=5432
DB_NAME=agenthive
DB_USER=agenthive
DB_PASSWORD=你的数据库密码

REDIS_HOST=172.24.146.165
REDIS_PORT=6379
REDIS_PASSWORD=你的Redis密码（如果没有留空）

# ---- LLM: Kimi Code API ----
# 获取地址：https://platform.kimi.com/
LLM_API_KEY=你的Kimi Code API Key
LLM_BASE_URL=https://api.kimi.com/coding/v1
LLM_MODEL=kimi-code

# ---- Cloudflare Tunnel Token ----
# https://one.dash.cloudflare.com/ -> Networks -> Tunnels
CF_TUNNEL_TOKEN=你的CloudflareTunnelToken

# ---- 本地端口 ----
DEMO_PORT=80
DEMO_HTTPS_PORT=443
API_PORT=3001
LANDING_PORT=3000

# ---- 其他 ----
JWT_SECRET=demo-jwt-secret-随便改一个长的
NUXT_PUBLIC_API_BASE=http://localhost:3001

# ---- Java 微服务（可选）----
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ---- 监控（可选）----
GRAFANA_PASSWORD=admin123
