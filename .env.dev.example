# ============================================================================
# AgentHive Cloud — Development Environment Template
# TICKET: TICKET-PLAT-DEV-003
#
# Copy this file to .env.dev and fill in the placeholders.
# Run `bash scripts/setup-dev-env.sh` to auto-generate missing secrets.
#
# WARNING: Never commit real secrets to version control.
# ============================================================================

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
DB_USER=agenthive
DB_PASSWORD=dev
DB_NAME=agenthive
DB_PORT=5433

# ---------------------------------------------------------------------------
# Cache (Redis)
# ---------------------------------------------------------------------------
REDIS_PASSWORD=agenthive
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# JWT — Used by Node API, Java Gateway, and Java Auth Service
# Must be identical across all services for cross-service token verification.
# Generate with: openssl rand -base64 32
# ---------------------------------------------------------------------------
JWT_SECRET=dxvmC6J4yjw7o0MxVhrEVQMNHfbWEf3J53YBAC7sRMNp7haLQE5WhYcWxScPXobD

# ---------------------------------------------------------------------------
# LLM Provider
# ---------------------------------------------------------------------------
LLM_API_KEY=<GENERATE>
LLM_BASE_URL=https://api.kimi.com/coding/v1
LLM_MODEL=kimi-for-coding

# ---------------------------------------------------------------------------
# Message Queue (RabbitMQ)
# ---------------------------------------------------------------------------
RABBITMQ_USER=agenthive
RABBITMQ_PASSWORD=agenthive-secret

# ---------------------------------------------------------------------------
# Service Discovery (Nacos)
# ---------------------------------------------------------------------------
# Nacos auth token for JWT signing (base64-encoded 256-bit secret).
# Must be identical across nacos server and all Java microservices.
# Generate with: openssl rand -base64 32
NACOS_AUTH_TOKEN=<GENERATE>

# Nacos identity value for server-to-server authentication.
# Generate with: openssl rand -base64 24 | tr -dc 'a-zA-Z0-9' | head -c 32
NACOS_AUTH_IDENTITY_VALUE=<GENERATE>

# Nacos password used by Java microservices to authenticate with Nacos.
# Must match the credentials configured in the Nacos server.
NACOS_PASSWORD=agenthive-secret-2024

# ---------------------------------------------------------------------------
# Optional / Service-specific
# ---------------------------------------------------------------------------
API_PORT=3001
LANDING_PORT=3000
GRAFANA_PASSWORD=admin123
CORS_ORIGIN=
OLLAMA_MODEL=qwen3:14b
ALIYUN_SMS_ENABLED=false
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
INTERNAL_API_TOKEN=
WITHDRAWAL_ENCRYPT_KEY=

# === Aliyun SMS ===
ALIYUN_SMS_DEFAULT_SIGN_NAME=
ALIYUN_SMS_OIDC_PROVIDER_ARN=
ALIYUN_SMS_OIDC_ROLE_ARN=
ALIYUN_SMS_TEMPLATE_CODE_RESET_PASSWORD=

# === Java Microservices Integration ===
JAVA_PAYMENT_URL=http://payment-service:8083

# === Nacos ===
NACOS_NAMESPACE=agenthive
