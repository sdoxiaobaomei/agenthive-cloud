# AgentHive Cloud - Development Environment Variables
# 用于 docker-compose.dev.yml 本地开发
# 复制为 .env.dev 并填入真实值
# ============================================
# Database（本地容器）
# ============================================
DB_HOST=postgres
DB_PORT=5433
DB_USER=agenthive
DB_PASSWORD=dev
DB_NAME=agenthive

# ============================================
# Redis（本地容器）
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379

# ============================================
# API / Landing
# ============================================
API_PORT=3001
LANDING_PORT=3000
CORS_ORIGIN=http://localhost,http://localhost:3000,http://localhost:5173,http://localhost:8088

# ============================================
# JWT（开发环境默认值，生产环境必须替换）
# ============================================
JWT_SECRET=

# ============================================
# LLM（Kimi Code API）
# ============================================
LLM_API_KEY=
LLM_BASE_URL=https://api.kimi.com/coding/v1
LLM_MODEL=kimi-for-coding
LLM_USER_AGENT=claude-code/0.1.0

# ============================================
# Ollama（宿主机本地模型，可选）
# ============================================
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3:14b

# ============================================
# Java / Nacos / RabbitMQ
# ============================================
NACOS_SERVER=nacos:8848
RABBITMQ_USER=agenthive
RABBITMQ_PASSWORD=agenthive-secret

# ============================================
# Aliyun SMS
# ============================================
ALIYUN_SMS_ENABLED=false
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=

# ============================================
# Monitoring
# ============================================
GRAFANA_PASSWORD=admin123
