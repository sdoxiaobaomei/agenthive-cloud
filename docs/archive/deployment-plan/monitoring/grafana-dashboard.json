{
  "dashboard": {
    "id": null,
    "uid": "agenthive-production-overview",
    "title": "AgentHive Cloud - Production Overview",
    "tags": ["agenthive", "production", "overview"],
    "timezone": "UTC",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "templating": {
      "list": [
        {
          "name": "namespace",
          "type": "constant",
          "current": {
            "value": "agenthive",
            "text": "agenthive"
          }
        },
        {
          "name": "cluster",
          "type": "constant",
          "current": {
            "value": "production",
            "text": "production"
          }
        }
      ]
    },
    "annotations": {
      "list": [
        {
          "name": "Deployments",
          "datasource": "Prometheus",
          "expr": "kube_deployment_status_condition{status=\"True\"}",
          "tagKeys": "deployment",
          "iconColor": "rgba(255, 96, 96, 1)",
          "enable": true
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "title": "Service Health Status",
        "type": "stat",
        "gridPos": {"h": 4, "w": 8, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "up{namespace=\"$namespace\"}",
            "legendFormat": "{{job}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {"options": {"0": {"text": "DOWN", "color": "red"}}, "type": "value"},
              {"options": {"1": {"text": "UP", "color": "green"}}, "type": "value"}
            ],
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "green", "value": 1}
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "Request Rate (req/s)",
        "type": "stat",
        "gridPos": {"h": 4, "w": 8, "x": 8, "y": 0},
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{namespace=\"$namespace\"}[5m]))",
            "legendFormat": "Total",
            "refId": "A"
          }
        ]
      },
      {
        "id": 3,
        "title": "Error Rate",
        "type": "stat",
        "gridPos": {"h": 4, "w": 8, "x": 16, "y": 0},
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{namespace=\"$namespace\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{namespace=\"$namespace\"}[5m]))",
            "legendFormat": "Error %",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 0.01},
                {"color": "red", "value": 0.05}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "API Latency (P50/P95/P99)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{namespace=\"$namespace\",job=\"api\"}[5m])) by (le))",
            "legendFormat": "P50",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{namespace=\"$namespace\",job=\"api\"}[5m])) by (le))",
            "legendFormat": "P95",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{namespace=\"$namespace\",job=\"api\"}[5m])) by (le))",
            "legendFormat": "P99",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "min": 0
          }
        }
      },
      {
        "id": 5,
        "title": "Agent Runtime - Task Queue",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
        "targets": [
          {
            "expr": "redis_key_size{namespace=\"$namespace\",key=\"agent-tasks\"}",
            "legendFormat": "Pending Tasks",
            "refId": "A"
          },
          {
            "expr": "sum(agent_tasks_active_total{namespace=\"$namespace\"})",
            "legendFormat": "Active Tasks",
            "refId": "B"
          }
        ]
      },
      {
        "id": 6,
        "title": "Pod Scaling",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
        "targets": [
          {
            "expr": "kube_deployment_status_replicas{namespace=\"$namespace\",deployment=\"landing\"}",
            "legendFormat": "Landing",
            "refId": "A"
          },
          {
            "expr": "kube_deployment_status_replicas{namespace=\"$namespace\",deployment=\"api\"}",
            "legendFormat": "API",
            "refId": "B"
          },
          {
            "expr": "kube_deployment_status_replicas{namespace=\"$namespace\",deployment=\"agent-runtime\"}",
            "legendFormat": "Agent Runtime",
            "refId": "C"
          }
        ]
      },
      {
        "id": 7,
        "title": "CPU Usage",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
        "targets": [
          {
            "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"$namespace\",container!=\"\"}[5m])) by (pod)",
            "legendFormat": "{{pod}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit"
          }
        }
      },
      {
        "id": 8,
        "title": "Memory Usage",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
        "targets": [
          {
            "expr": "container_memory_usage_bytes{namespace=\"$namespace\",container!=\"\"} / container_spec_memory_limit_bytes{namespace=\"$namespace\",container!=\"\"}",
            "legendFormat": "{{pod}} - {{container}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "max": 1
          }
        }
      },
      {
        "id": 9,
        "title": "Database Connections",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
        "targets": [
          {
            "expr": "pg_stat_activity_count{namespace=\"$namespace\"}",
            "legendFormat": "Active Connections",
            "refId": "A"
          },
          {
            "expr": "pg_settings_max_connections{namespace=\"$namespace\"}",
            "legendFormat": "Max Connections",
            "refId": "B"
          }
        ]
      },
      {
        "id": 10,
        "title": "LLM API Metrics",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 28},
        "targets": [
          {
            "expr": "rate(llm_api_calls_total{namespace=\"$namespace\"}[5m])",
            "legendFormat": "Calls/sec",
            "refId": "A"
          },
          {
            "expr": "rate(llm_api_errors_total{namespace=\"$namespace\"}[5m])",
            "legendFormat": "Errors/sec",
            "refId": "B"
          }
        ]
      },
      {
        "id": 11,
        "title": "Agent Task Success Rate",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 28},
        "targets": [
          {
            "expr": "1 - (sum(rate(agent_tasks_failed_total{namespace=\"$namespace\"}[1h])) / sum(rate(agent_tasks_total{namespace=\"$namespace\"}[1h])))",
            "legendFormat": "Success Rate",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 0.95},
                {"color": "green", "value": 0.99}
              ]
            }
          }
        }
      },
      {
        "id": 12,
        "title": "Cost Overview (Last 30 Days)",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 32},
        "targets": [
          {
            "expr": "sum(kube_pod_container_resource_requests{namespace=\"$namespace\",resource=\"cpu\"}) by (container) * 30 * 24 * 0.05",
            "legendFormat": "{{container}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD"
          }
        }
      }
    ]
  }
}
