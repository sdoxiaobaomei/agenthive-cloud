# ============================================================================
# ASK Demo 环境 - 变量定义
# ============================================================================
# 变量(variable)的作用: 将配置中可能变化的部分抽离出来，实现"代码复用"。
# 使用方式:
#   1. 创建 terraform.tfvars 文件，直接赋值
#   2. 命令行传入: terraform apply -var="region=cn-shanghai"
#   3. 环境变量: TF_VAR_region=cn-shanghai terraform apply
# ============================================================================

# ----------------------------------------------------------------------------
# variable "region": 阿里云地域
# ----------------------------------------------------------------------------
# description: 变量的说明文字，terraform plan/apply 时会显示，帮助他人理解用途
# type: 变量的数据类型
#   string = 字符串（文本）
#   number = 数字
#   bool = 布尔值（true/false）
#   list(string) = 字符串数组
#   map(string) = 键值对（字典）
#   object({...}) = 结构化对象
# default: 默认值。如果用户没有提供此变量，就使用默认值。
#   适合有合理默认值的参数，减少重复配置。
variable "region" {
  description = "阿里云地域 ID，决定资源创建在哪个数据中心"
  type        = string
  default     = "cn-beijing"
}

# ----------------------------------------------------------------------------
# variable "zone_id": 可用区
# ----------------------------------------------------------------------------
# 可用区(Zone)是地域内的独立物理数据中心，拥有独立的电力和网络。
# 同一地域的不同可用区之间通过高速内网连接（延迟 < 2ms）。
#
# 为什么需要显式指定?
#   - ASK 集群的 VSwitch 必须绑定到具体可用区
#   - 不同可用区支持的实例规格不同
#   - 可用区格式: {region}-{letter}，如 cn-beijing-a, cn-beijing-b
#
# 选择建议:
#   - Demo 场景选任意一个即可（单可用区足够）
#   - 生产场景建议跨 2-3 个可用区部署，实现高可用
variable "zone_id" {
  description = "可用区 ID，如 cn-beijing-a。ASK 只需单可用区。"
  type        = string
  default     = "cn-beijing-a"
}

# ----------------------------------------------------------------------------
# variable "project_name": 项目名称
# ----------------------------------------------------------------------------
# 所有资源名称都会加上此前缀，方便识别归属。
# 例如: project_name="agenthive" → 集群名称为 "agenthive-demo-ask"
#
# 命名规范:
#   - 只允许字母、数字、连字符(-)、下划线(_)
#   - 不能以数字开头
#   - 长度适中，太长会被某些服务截断
variable "project_name" {
  description = "项目名称，用于所有资源的命名前缀"
  type        = string
  default     = "agenthive"
}
