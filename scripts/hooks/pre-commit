#!/bin/bash
# Git Pre-Commit Hook
# Ensures code quality before commit

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo "🔍 Running pre-commit checks..."
echo ""

# Get commit message from file (if provided)
COMMIT_MSG_FILE=$1
if [ -n "$COMMIT_MSG_FILE" ]; then
    COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")
    
    # Check commit message format
    if ! echo "$COMMIT_MSG" | grep -qE '^\[[a-z-]+\] [A-Z]+-[0-9]+:'; then
        echo -e "${YELLOW}⚠️  Commit message format suggestion:${NC}"
        echo "   Format: [agent-name] FEATURE-ID: description"
        echo "   Example: [backend-dev] BE-002: implement user login"
        echo ""
        echo -e "${GREEN}✓ Continuing with commit...${NC}"
        echo ""
    fi
fi

# Check for sensitive files
echo "🔒 Checking for sensitive files..."
SENSITIVE_PATTERNS="\.env\.local$|\.env$|\.key$|\.pem$|password|secret|token"
STAGED_FILES=$(git diff --cached --name-only)

for file in $STAGED_FILES; do
    if echo "$file" | grep -qE "$SENSITIVE_PATTERNS"; then
        echo -e "${RED}❌ Potentially sensitive file staged: $file${NC}"
        echo "   Review before committing."
        exit 1
    fi
done
echo -e "${GREEN}✓ No sensitive files detected${NC}"

# Check file size (warn if > 1MB)
echo ""
echo "📦 Checking file sizes..."
LARGE_FILES=$(git diff --cached --numstat | awk '$1 > 1000 || $2 > 1000 {print $3}')
if [ -n "$LARGE_FILES" ]; then
    echo -e "${YELLOW}⚠️  Large files detected (>1MB):${NC}"
    echo "$LARGE_FILES" | sed 's/^/   /'
fi

echo ""
echo -e "${GREEN}✅ Pre-commit checks passed${NC}"
