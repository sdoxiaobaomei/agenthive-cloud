# AgentHive Cloud - Production Environment Variables
# 用于 docker-compose.prod.yml ECS 部署
# ⚠️ 生产环境请确保所有密码已替换为强密码
# 复制为 .env.prod 并填入真实值

# ============================================
# Database（远端 2+2 ECS）
# ============================================
DB_HOST=172.24.146.165
DB_PORT=5432
DB_USER=agenthive
DB_PASSWORD=
DB_NAME=agenthive

# ============================================
# Redis（远端 2+2 ECS）
# ============================================
REDIS_HOST=172.24.146.165
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# API / Landing / Nginx
# ============================================
API_PORT=3001
LANDING_PORT=3000
NGINX_PORT=80
NGINX_HTTPS_PORT=443

# ============================================
# JWT（生产环境必须设置 ≥32 位强密码）
# ============================================
JWT_SECRET=

# ============================================
# 镜像地址
# ============================================
# 默认使用 latest，发版时可替换为具体版本号（如 v1.0.0）
# 版本号通过 git tag v1.0.0 && git push origin v1.0.0 触发 CI 构建
# 或使用 ./scripts/bump-version.sh [patch|minor|major] 自动递增
API_IMAGE=crpi-89ktoa4wv8sjcdow.cn-beijing.personal.cr.aliyuncs.com/namespace-alpha/api:latest
LANDING_IMAGE=crpi-89ktoa4wv8sjcdow.cn-beijing.personal.cr.aliyuncs.com/namespace-alpha/landing:latest

# ============================================
# LLM（Kimi Code API）
# ============================================
LLM_API_KEY=
LLM_BASE_URL=https://api.kimi.com/coding/v1
LLM_MODEL=kimi-for-coding
LLM_USER_AGENT=claude-code/0.1.0

# ============================================
# CORS
# ============================================
CORS_ORIGIN=http://localhost,https://localhost

# ============================================
# Java / Nacos / RabbitMQ
# ============================================
NACOS_AUTH_TOKEN=<NACOS_AUTH_TOKEN_EXAMPLE>
RABBITMQ_USER=agenthive
RABBITMQ_PASSWORD=

# ============================================
# Aliyun SMS
# ============================================
ALIYUN_SMS_ENABLED=false
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=

# ============================================
# Monitoring
# ============================================
GRAFANA_PASSWORD=

# ============================================
# Java Microservices Images
# ============================================
GATEWAY_IMAGE=crpi-89ktoa4wv8sjcdow.cn-beijing.personal.cr.aliyuncs.com/namespace-alpha/gateway-service:latest
AUTH_IMAGE=crpi-89ktoa4wv8sjcdow.cn-beijing.personal.cr.aliyuncs.com/namespace-alpha/auth-service:latest
USER_IMAGE=crpi-89ktoa4wv8sjcdow.cn-beijing.personal.cr.aliyuncs.com/namespace-alpha/user-service:latest
PAYMENT_IMAGE=crpi-89ktoa4wv8sjcdow.cn-beijing.personal.cr.aliyuncs.com/namespace-alpha/payment-service:latest
ORDER_IMAGE=crpi-89ktoa4wv8sjcdow.cn-beijing.personal.cr.aliyuncs.com/namespace-alpha/order-service:latest
CART_IMAGE=crpi-89ktoa4wv8sjcdow.cn-beijing.personal.cr.aliyuncs.com/namespace-alpha/cart-service:latest
LOGISTICS_IMAGE=crpi-89ktoa4wv8sjcdow.cn-beijing.personal.cr.aliyuncs.com/namespace-alpha/logistics-service:latest
